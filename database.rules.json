{
  "rules": {
    "lobbies": {
      ".read": true,
      "$lobbyId": {
        ".write": true
      }
    },
    "clans": {
      ".read": true,
      "$clanId": {
        ".write": true,
        "members": {
          "$uid": {
            ".write": true
          }
        }
      }
    },
    "chat": {
      "global": {
        ".read": true,
        ".write": true
      },
      "rooms": {
        "$roomId": {
          ".read": true,
          ".write": true
        }
      },
      "clan": {
        "$clanId": {
          ".read": true,
          ".write": true
        }
      }
    },
    "userSearch": {
      ".read": true,
      "$uid": {
        ".write": true
      }
    },
    "users": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid",
        "friends": {
          ".read": true,
          ".write": "auth != null && auth.uid === $uid"
        },
        "friendRequests": {
          ".read": true,
          "$fromUid": {
            ".write": true
          }
        }
      }
    },
    "rooms": {
      ".read": true,
      "$roomId": {
        ".write": true
      }
    },
    "leaderboard": {
      ".read": true,
      "$uid": {
        ".write": true
      }
    }
  }
}
