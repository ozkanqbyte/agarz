{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "cd server && npm install"
  },
  "deploy": {
    "startCommand": "cd server && node server.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
